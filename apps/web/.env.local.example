# ProofOS web app env template
# Copy this file to: apps/web/.env.local (for local dev only)
# For Vercel: add these keys in Project Settings -> Environment Variables.
# Never commit apps/web/.env.local.

# =============================================================================
# Required for production deployment
# =============================================================================

# WalletConnect (client-side; exposed to browser)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# EVM transfer indexer (server-side API route)
# Use either ALCHEMY_API_KEY or a full ALCHEMY_BASE_SEPOLIA_URL.
ALCHEMY_API_KEY=your_alchemy_api_key
# ALCHEMY_BASE_SEPOLIA_URL=https://base-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# Contracts used by UI/proof flow (client-side)
NEXT_PUBLIC_CAIRO_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_TAX_VERIFIER_ADDRESS=0x...

# =============================================================================
# Recommended defaults
# =============================================================================

NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7
ENS_SUBGRAPH_URL=https://api.studio.thegraph.com/query/49574/enssepolia/version/latest

# =============================================================================
# Optional integrations
# =============================================================================

# HeyElsa AI tax advisor API route (/api/tax/advice)
# ELSA_API_KEY=your_elsa_api_key

# Fileverse document APIs (/api/ddocs/*)
# If you only use ddocs API key-based share links:
# FILEVERSE_API_KEY=your_fileverse_api_key
# NEXT_PUBLIC_FILEVERSE_API_KEY=your_fileverse_api_key

# If you use agent-based publish route (/api/fileverse/publish):
# FILEVERSE_PRIVATE_KEY=0x...
# PIMLICO_API_KEY=your_pimlico_api_key
# PINATA_JWT=your_pinata_jwt
# PINATA_GATEWAY=https://gateway.pinata.cloud
# NEXT_PUBLIC_FILEVERSE_NAMESPACE=proofos-reports
